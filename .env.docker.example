# Required LLM settings
OPENAI_API_KEY=replace-me
OPENAI_BASE_URL=https://integrate.api.nvidia.com/v1
MODEL_NAME=nvidia/nemotron-3-super-120b-a12b

# Crawl and output settings
LANGUAGE=Chinese
CATEGORIES=cs.RO,cs.AI,cs.LG,cs.CV
AI_MAX_WORKERS=4

# Git author for local Docker commits
EMAIL=your-email@example.com
NAME=Your Name

# GitHub repository info. Leave blank to infer from git remote origin when possible.
REPO_OWNER=Altman-conquer
REPO_NAME=robotics-daily-arXiv

# Optional. Used by enhance.py to query GitHub repo metadata from paper abstracts.
TOKEN_GITHUB=

# Optional. If set, enables password protection by injecting SHA-256 hash.
ACCESS_PASSWORD=

# Push behavior
PUSH_CHANGES=true

# SSH key paths inside the container. docker-compose.yml mounts your Windows SSH
# files to these paths and the runner copies the private key to a 600-permission
# temporary file before git push.
SSH_PRIVATE_KEY_FILE=/run/host-ssh/id_ed25519
SSH_PUBLIC_KEY_FILE=/run/host-ssh/id_ed25519.pub

# HTTPS push token fallback. Prefer SSH if your origin is git@github.com:owner/repo.git
# and you mount your SSH key into the container. If you use this token, it needs repo write access.
GIT_PUSH_TOKEN=

# Safety guard. Keep false for normal use. Set true only if you intentionally want
# Docker to run with local uncommitted changes present in the mounted repository.
ALLOW_DIRTY_WORKTREE=false
